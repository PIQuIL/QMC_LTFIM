#!/bin/bash
#SBATCH --time=24:00:00
#SBATCH --nodes=1
#SBATCH --cpus-per-task=32
#SBATCH --mem=0
#SBATCH --mail-user=emerali@uwaterloo.ca
#SBATCH --mail-type=TIME_LIMIT
#SBATCH --account=rrg-rgmelko-ab
#SBATCH --output=/scratch-deleted-2021-mar-20/ejaazm/qmc_sims/improved_lines/disordered_2_checkerboard/logs/output-%x-%j.out
echo delta=$delta

M=100000

JOBLOG="/scratch-deleted-2021-mar-20/ejaazm/qmc_sims"
JOBLOG="$JOBLOG/disordered_2_checkerboard/joblogs"

mkdir -p $JOBLOG

JOBLOG_MCMC="$JOBLOG/joblog-$SLURM_JOB_NAME-$SLURM_JOB_ID-mcmc.log"
JOBLOG_AGGR="$JOBLOG/joblog-$SLURM_JOB_NAME-$SLURM_JOB_ID-aggr.log"

module load StdEnv/2020 julia/1.5.2
parallel --jobs $SLURM_CPUS_PER_TASK -k --group --joblog $JOBLOG_MCMC \
	julia --compiled-modules=no --project=../ rydberg_experiment_saveall.jl \
		groundstate {1} \
		--omega 1.0 -R 1.2 --delta $delta \
		-n 131072 -b 32 \
		--seed {2} -M $M \
		::: $(seq 8 8 32) \
		::: $(shuf -i 0-10000 -n 8)

parallel --jobs 4 -k --group --joblog $JOBLOG_AGGR \
	julia --compiled-modules=no --project=../ rydberg_cleanup.jl {} $delta $M \
		::: $(seq 8 8 32)
