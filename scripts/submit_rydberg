#!/bin/bash
#SBATCH --time=6:00:00
#SBATCH --cpus-per-task=4
#SBATCH --mem-per-cpu=8G
#SBATCH --account=rrg-rgmelko-ab
#SBATCH --output=/scratch-deleted-2021-mar-20/ejaazm/qmc_sims/improved_lines/delta_scan/logs/output-%x-%A-%a.out
#SBATCH --array=4-10:2
echo nY=$SLURM_ARRAY_TASK_ID
echo delta=$delta
echo M=$M
echo p=$p
module load StdEnv/2020 julia/1.5.2
parallel --jobs $SLURM_CPUS_PER_TASK -k --group \
	julia --compiled-modules=no --project=../ rydberg_experiment_binning.jl \
		groundstate $SLURM_ARRAY_TASK_ID \
		--omega 1.0 -R 1.2 --delta $delta -n 100000 -b 25 -M $M --mb-prob $p \
		--seed {} ::: $(shuf -i 0-10000 -n $SLURM_CPUS_PER_TASK)

