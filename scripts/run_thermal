for beta in ${beta_vals[@]} ; do
  # echo "run $beta"
  for seed in $(seq 1000 500 5500) ; do
    echo "run beta=$beta, seed=$seed"
    julia --compiled-modules=no --project=../ rydberg_experiment_thermal.jl \
      thermal 5 "./data/rydberg_gpt/" \
      --omega 1.0 -R 1.15 --delta 1.05 \
      -n 10000 -b 100 --mb-prob 0.0 --beta $beta \
      --seed $seed -M 100000 --runstats 0
  done
done